{
  "name": "@meshii/protocol",
  "version": "0.1.0",
  "description": "Meshii Protocol cryptographic primitives — X3DH, Double Ratchet, W3C VC, SIWE, relay capability tokens",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^1.7.0",
    "@noble/hashes": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^1.6.0"
  }
}
